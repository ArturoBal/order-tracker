# Application
NODE_ENV=development
PORT=3000

# CORS: comma-separated list of allowed origins (empty = allow all, e.g. in dev)
CORS_ORIGIN=

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=order_tracker
# Set to "true" when connecting to a Postgres instance that requires SSL (e.g. external connections)
DB_SSL=false
